{
  "geode": "5.6.1",
  "gd": {
    "win": "2.2081",
    "mac": "2.2081"
  },
  "name": "AutoDeafen",
  "developer": "Lynxdeer",
  "version": "1.2.3",
  "id": "lynxdeer.autodeafen",
  "description": "A mod that automatically hits a configurable deafen keybind at a certain percentage. Configurable per-level.",
  "tags": ["enhancement", "utility"],
  "repository": "https://github.com/FusedBjorn333/AutoDeafenOld",
  "early-load": true,

  "settings": {
    "Enabled by Default": {
      "type": "bool",
      "default": false,
      "description": "Whether AutoDeafen is enabled by default when entering a level."
    },
    "Default Percentage": {
      "type": "int",
      "default": 50,
      "min": 0,
      "max": 100,
      "description": "Default percentage to trigger deafen."
    },
    "Enabled in Practice Mode": {
      "type": "bool",
      "default": false,
      "description": "Enable AutoDeafen in practice mode."
    },
    "Additional Debugging": {
      "type": "bool",
      "default": false,
      "description": "Enable extra debug logging."
    }
  },

  "dependencies": {
    "geode.node-ids": {
      "version": ">=1.12.0",
      "importance": "required"
    }
  }
}
